{
  "project_name": "metadata-driven-data-platform",
  "dataset_name": "curated_orders",
  "source_files": {
    "orders": "data/raw/orders.csv",
    "customers": "data/raw/customers.csv"
  },
  "outputs": {
    "curated_orders": "data/curated/curated_orders.csv",
    "validation_report": "outputs/validation_report.csv",
    "metadata_summary": "outputs/metadata_summary.json",
    "lineage": "outputs/lineage.json"
  },
"validation_rules": [
    {
      "name": "order_id_not_null",
      "column": "order_id",
      "rule": "not_null"
    },
    {
      "name": "customer_id_not_null",
      "column": "customer_id",
      "rule": "not_null"
    },
    {
      "name": "sales_amount_positive",
      "column": "sales_amount",
      "rule": "greater_than",
      "value": 0
    },
    {
      "name": "order_id_unique",
      "column": "order_id",
      "rule": "unique"
    }
  ]
}